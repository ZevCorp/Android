{
  "name": "miracle-windows-shell",
  "version": "0.1.0",
  "private": true,
  "description": "Caparazón Windows (Electron) que embebe la webapp desplegada y lanza la carita flotante Ü.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.5"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.zevcorp.miracle.windows",
    "productName": "Miracle",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "config.js",
      "package.json",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/assistant",
        "to": "assistant",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Miracle"
    },
    "publish": null
  }
}
