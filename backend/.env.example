# Copia a .env.local para `vercel dev`, o configúralas en Vercel → Project → Settings → Environment Variables.

# OBLIGATORIA: key de OpenAI (Responses API con computer-use).
OPENAI_API_KEY=sk-...

# Modelo con computer-use. Cambiable sin tocar el cliente.
MODEL=gpt-5.6

# reasoning.effort: none/minimal/low/medium/high/xhigh (low = recomendado para computer-use).
EFFORT=low

# Secreto HMAC para firmar el blob de sesión opaco (pon algo largo y aleatorio).
SESSION_SECRET=

# Token Bearer que los clientes deben mandar (opcional; si vacío, la API queda abierta en dev).
CLIENT_TOKEN=
