# Copia a .env.local para el servidor local (`npm run local`), o configúralas en
# Vercel → Project → Settings → Environment Variables.

# Proveedor del cerebro: gemini | openai
PROVIDER=gemini

# --- Gemini (Google) ---
GEMINI_API_KEY=AQ...
GEMINI_MODEL=gemini-3.5-flash

# --- OpenAI (si PROVIDER=openai) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.6
# reasoning.effort: none/minimal/low/medium/high/xhigh (low = recomendado para computer-use).
EFFORT=low

# Secreto HMAC para firmar el blob de sesión opaco (pon algo largo y aleatorio).
SESSION_SECRET=

# Token Bearer que los clientes deben mandar (opcional; si vacío, la API queda abierta en dev).
CLIENT_TOKEN=
