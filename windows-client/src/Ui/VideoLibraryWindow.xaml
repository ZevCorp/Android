<Window x:Class="U.WindowsClient.Ui.VideoLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Videos de enseñanza" Width="820" Height="560"
        Background="#FF101014" WindowStartupLocation="CenterScreen">

    <!-- Biblioteca local: lista a la izquierda, reproductor (MediaElement, nativo de WPF) a la
         derecha. Sin dependencias externas: es la forma más simple de reproducir un mp4 en WPF, y
         basta para "ver lo que grabé", que es todo lo que pide este panel. -->
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="14"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0">
            <TextBlock DockPanel.Dock="Top" Text="Videos guardados" Foreground="#EEFFFFFF"
                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Button DockPanel.Dock="Bottom" x:Name="DeleteBtn" Content="🗑 Borrar seleccionado"
                    Height="30" Margin="0,10,0,0" Click="OnDelete"
                    Background="#33FF3B30" Foreground="White" BorderThickness="0"/>
            <Button DockPanel.Dock="Bottom" x:Name="OpenFolderBtn" Content="📂 Abrir carpeta"
                    Height="30" Margin="0,6,0,0" Click="OnOpenFolder"
                    Background="#22FFFFFF" Foreground="White" BorderThickness="0"/>
            <ListBox x:Name="List" Background="#18FFFFFF" Foreground="White" BorderThickness="0"
                     SelectionChanged="OnSelected"/>
        </DockPanel>

        <Border Grid.Column="2" Background="#18000000" CornerRadius="8">
            <Grid>
                <MediaElement x:Name="Player" LoadedBehavior="Manual" UnloadedBehavior="Manual"
                              Stretch="Uniform" Margin="1" MediaEnded="OnMediaEnded"/>
                <TextBlock x:Name="Empty" Text="Selecciona un video de la izquierda"
                           Foreground="#66FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                            Margin="0,0,0,14">
                    <Button x:Name="PlayBtn" Content="▶" Width="44" Height="34" Click="OnPlayPause"
                            Background="#33FFFFFF" Foreground="White" BorderThickness="0" FontSize="16"/>
                    <TextBlock x:Name="Caption" Foreground="#CCFFFFFF" VerticalAlignment="Center"
                               Margin="12,0,0,0" MaxWidth="400" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
