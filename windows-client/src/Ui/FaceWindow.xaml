<Window x:Class="U.WindowsClient.Ui.FaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ü"
        Width="320"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        ResizeMode="NoResize" SizeToContent="Height">

    <!-- Carita flotante: overlay permanente, arrastrable, siempre encima. Es TODO el frontend visible.
         No decide nada; solo muestra el estado y recoge lo que el usuario pide. -->
    <Grid>
        <Border x:Name="Panel" CornerRadius="18" Background="#F2101014" Padding="14"
                BorderBrush="#33FFFFFF" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.5" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <!-- Cabecera arrastrable: la carita + estado -->
                <DockPanel x:Name="Header" LastChildFill="True" Cursor="SizeAll">
                    <Ellipse x:Name="Face" Width="40" Height="40" DockPanel.Dock="Left">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FFFFFFFF" Offset="0.0"/>
                                <GradientStop Color="#FFB9C7FF" Offset="1.0"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock x:Name="Status" Text="Ü listo" Foreground="#EEFFFFFF" FontSize="13"
                               VerticalAlignment="Center" Margin="10,0,0,0" TextWrapping="Wrap"/>
                </DockPanel>

                <!-- Globo de narración -->
                <TextBlock x:Name="Bubble" Text="" Foreground="#CCFFFFFF" FontSize="12"
                           Margin="0,10,0,0" TextWrapping="Wrap" MaxHeight="60"/>

                <!-- Pastilla de actualización: oculta salvo que ya haya una versión descargada y lista.
                     Si el usuario la ignora, se aplica sola al cerrar (ver Updater.ApplyOnExit). -->
                <Button x:Name="UpdateBtn" Content="⬇ Nueva versión lista — reiniciar" Height="28"
                        Margin="0,10,0,0" Click="OnApplyUpdate" Background="#553B82F6" Foreground="White"
                        BorderThickness="0" FontSize="11" Visibility="Collapsed"
                        ToolTip="Se instalará sola al cerrar Ü si prefieres seguir trabajando"/>

                <!-- Entrada de texto + micrófono -->
                <DockPanel Margin="0,12,0,0" LastChildFill="True">
                    <Button x:Name="MicBtn" Content="🎤" DockPanel.Dock="Right" Width="34" Height="30"
                            Margin="6,0,0,0" Click="OnMic" Background="#22FFFFFF" Foreground="White" BorderThickness="0"/>
                    <!-- Siempre visible: callarlo tiene que estar a un clic, sin importar qué esté pasando. -->
                    <Button x:Name="MuteBtn" Content="🔊" DockPanel.Dock="Right" Width="34" Height="30"
                            Margin="6,0,0,0" Click="OnToggleMute" Background="#22FFFFFF" Foreground="White"
                            BorderThickness="0" ToolTip="Callar a Ü ahora mismo"/>
                    <Button x:Name="StopBtn" Content="⏹" DockPanel.Dock="Right" Width="34" Height="30"
                            Margin="6,0,0,0" Click="OnStop" Background="#55FF3B30" Foreground="White" BorderThickness="0"
                            Visibility="Collapsed"/>
                    <TextBox x:Name="Input" Height="30" VerticalContentAlignment="Center"
                             Background="#22FFFFFF" Foreground="White" BorderThickness="0" Padding="8,0"
                             KeyDown="OnInputKey"/>
                </DockPanel>

                <!-- Enseñanza activa: graba pantalla+voz para que Ü aprenda a usar una app. -->
                <DockPanel Margin="0,8,0,0" LastChildFill="True">
                    <Button x:Name="LogsBtn" Content="📜" DockPanel.Dock="Right" Width="34" Height="30"
                            Margin="6,0,0,0" Click="OnOpenLogs" Background="#22FFFFFF" Foreground="White"
                            BorderThickness="0" FontSize="11" ToolTip="Registro (para diagnosticar errores)"/>
                    <Button x:Name="WorkflowsBtn" Content="🧭" DockPanel.Dock="Right" Width="34" Height="30"
                            Margin="6,0,0,0" Click="OnOpenWorkflows" Background="#22FFFFFF" Foreground="White"
                            BorderThickness="0" FontSize="13"
                            ToolTip="Workflows: enseñar/ejecutar contra Graph (SAP GUI / UIA) + autofill"/>
                    <Button x:Name="VideosBtn" Content="🎞 Videos" DockPanel.Dock="Right" Width="76" Height="30"
                            Margin="6,0,0,0" Click="OnOpenVideos" Background="#22FFFFFF" Foreground="White"
                            BorderThickness="0" FontSize="11"/>
                    <!-- Solo visible mientras se graba: descarta lo grabado y vuelve a empezar, sin que el
                         error llegue nunca a Gemini ni al cerebro. Ver TeachSession.RestartAsync. -->
                    <Button x:Name="RestartTeachBtn" Content="🔄" DockPanel.Dock="Right" Width="34" Height="30"
                            Margin="6,0,0,0" Click="OnRestartTeach" Background="#22FFFFFF" Foreground="White"
                            BorderThickness="0" FontSize="11" Visibility="Collapsed"
                            ToolTip="Me equivoqué: descartar esta grabación y empezar de nuevo"/>
                    <Button x:Name="TeachBtn" Content="🎓 Enseñar" Height="30" Click="OnToggleTeach"
                            Background="#22FFFFFF" Foreground="White" BorderThickness="0" FontSize="11"/>
                </DockPanel>

                <!-- Ajustes mínimos: dónde vive el cerebro -->
                <Expander Header="Backend" Foreground="#88FFFFFF" FontSize="11" Margin="0,10,0,0">
                    <StackPanel Margin="0,6,0,0">
                        <TextBox x:Name="BackendUrl" Height="26" Background="#22FFFFFF" Foreground="White"
                                 BorderThickness="0" Padding="6,0" VerticalContentAlignment="Center"/>
                        <TextBox x:Name="ClientToken" Height="26" Margin="0,6,0,0" Background="#22FFFFFF"
                                 Foreground="White" BorderThickness="0" Padding="6,0" VerticalContentAlignment="Center"/>
                        <Button Content="Guardar" Height="26" Margin="0,6,0,0" Click="OnSaveConfig"
                                Background="#33FFFFFF" Foreground="White" BorderThickness="0"/>
                        <!-- Para soporte: saber qué versión tiene el cliente delante sin pedirle nada. -->
                        <TextBlock x:Name="VersionText" Text="" Foreground="#66FFFFFF" FontSize="10"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Border>
    </Grid>
</Window>
