<Window x:Class="U.WindowsClient.Ui.WorkflowLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workflows (Graph)" Width="960" Height="660"
        Background="#FF101014" WindowStartupLocation="CenterScreen">

    <!-- Enseñar/ejecutar workflows contra Graph (SAP GUI Scripting / UIA) + autofill en vivo por nota.
         Mismo look plano que VideoLibraryWindow: lista a la izquierda, panel de trabajo a la derecha. -->
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="14"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Columna izquierda: conexión + enseñar + lista ─────────────────────────── -->
        <DockPanel Grid.Column="0">
            <TextBlock DockPanel.Dock="Top" Text="Workflows" Foreground="#EEFFFFFF"
                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

            <Expander DockPanel.Dock="Top" Header="Conexión a Graph" Foreground="#88FFFFFF" FontSize="11"
                      Margin="0,0,0,10">
                <StackPanel Margin="0,6,0,0">
                    <TextBox x:Name="GraphUrl" Height="26" Background="#22FFFFFF" Foreground="White"
                             BorderThickness="0" Padding="6,0" VerticalContentAlignment="Center"/>
                    <TextBox x:Name="GraphApiKey" Height="26" Margin="0,6,0,0" Background="#22FFFFFF"
                             Foreground="White" BorderThickness="0" Padding="6,0" VerticalContentAlignment="Center"
                             ToolTip="API key permanente de Graph (X-API-Key)"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button x:Name="SaveConnBtn" Content="Guardar" Height="26" Width="80" Click="OnSaveConnection"
                                Background="#33FFFFFF" Foreground="White" BorderThickness="0"/>
                        <Button x:Name="TestConnBtn" Content="Probar conexión" Height="26" Margin="6,0,0,0"
                                Click="OnTestConnection" Background="#33FFFFFF" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                    <TextBlock x:Name="ConnStatus" Text="" Foreground="#88FFFFFF" FontSize="10"
                               Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Expander>

            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                <TextBox x:Name="TeachDescription" Height="26" Background="#22FFFFFF" Foreground="White"
                         BorderThickness="0" Padding="6,0" VerticalContentAlignment="Center"
                         Text="" ToolTip="Descripción corta del workflow (obligatoria antes de enseñar)"/>
                <TextBlock Text="Describe el workflow antes de tocar Enseñar" Foreground="#66FFFFFF"
                           FontSize="10" Margin="0,4,0,0"/>
                <Button x:Name="TeachBtn" Content="● Enseñar workflow" Height="30" Margin="0,8,0,0"
                        Click="OnToggleTeach" Background="#22FFFFFF" Foreground="White" BorderThickness="0"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                <Button x:Name="RunBtn" Content="▶ Ejecutar ahora" Height="30" Click="OnRunSelected"
                        Background="#334CD964" Foreground="White" BorderThickness="0"/>
                <CheckBox x:Name="ForceSurface" Content="Forzar aunque la pantalla no coincida"
                          Foreground="#88FFFFFF" FontSize="10" Margin="0,6,0,0"/>
                <Button x:Name="ReloadBtn" Content="🔄 Actualizar lista" Height="26" Margin="0,8,0,0"
                        Click="OnReload" Background="#22FFFFFF" Foreground="White" BorderThickness="0"/>
            </StackPanel>

            <ListBox x:Name="WorkflowList" Background="#18FFFFFF" Foreground="White" BorderThickness="0"/>
        </DockPanel>

        <!-- ── Columna derecha: progreso de ejecución + autofill en vivo ─────────────────────────── -->
        <TabControl Grid.Column="2" Background="#18000000" BorderThickness="0">
            <TabItem Header="Progreso">
                <DockPanel Margin="10">
                    <TextBlock DockPanel.Dock="Top" x:Name="StatusLine" Text="Listo."
                               Foreground="#CCFFFFFF" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ProgressLog" Foreground="#AAFFFFFF" FontSize="11"
                                   FontFamily="Consolas" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <TabItem Header="Autofill en vivo">
                <DockPanel Margin="10">
                    <TextBlock DockPanel.Dock="Top" Text="Nota (dictado o escrita) — se propone, nunca se aplica solo"
                               Foreground="#88FFFFFF" FontSize="11" Margin="0,0,0,6"/>
                    <TextBox DockPanel.Dock="Top" x:Name="NoteBox" Height="90" AcceptsReturn="True"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             Background="#22FFFFFF" Foreground="White" BorderThickness="0" Padding="6"
                             TextChanged="OnNoteChanged"/>
                    <TextBlock DockPanel.Dock="Top" x:Name="AutofillStatus" Text="" Foreground="#66FFFFFF"
                               FontSize="10" Margin="0,6,0,10"/>
                    <ListBox x:Name="MatchesList" Background="#18FFFFFF" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#22FFFFFF" BorderThickness="0,0,0,1" Padding="0,8">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="Aplicar" Width="70" Height="26" Tag="{Binding}"
                                                    Click="OnApplyMatch" Background="#334CD964" Foreground="White" BorderThickness="0"/>
                                            <Button Content="Rechazar" Width="70" Height="26" Margin="6,0,0,0" Tag="{Binding}"
                                                    Click="OnRejectMatch" Background="#33FF3B30" Foreground="White" BorderThickness="0"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Label}" Foreground="#EEFFFFFF" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Value}" Foreground="#CCFFFFFF" FontSize="12" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding ConfidenceLabel}" Foreground="#88FFFFFF" FontSize="10"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
