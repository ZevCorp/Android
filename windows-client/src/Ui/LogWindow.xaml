<Window x:Class="U.WindowsClient.Ui.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registro de Ü" Width="700" Height="480"
        Background="#FF101014" WindowStartupLocation="CenterScreen">

    <!-- Bitácora en vivo: LogBus.Log(...) alimenta esto. Existe para que un fallo en una tarea de
         fondo (que antes se perdía en silencio) quede visible con su mensaje real. -->
    <DockPanel Margin="12">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10" LastChildFill="False">
            <TextBlock Text="Registro" Foreground="#EEFFFFFF" FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <Button Content="🗑 Limpiar" Click="OnClear" DockPanel.Dock="Right" Height="26"
                    Background="#22FFFFFF" Foreground="White" BorderThickness="0" Padding="10,0"/>
            <Button x:Name="CopyBtn" Content="📋 Copiar" Click="OnCopy" DockPanel.Dock="Right" Height="26"
                    Margin="0,0,8,0" Background="#22FFFFFF" Foreground="White" BorderThickness="0" Padding="10,0"/>
        </DockPanel>
        <ListBox x:Name="List" Background="#18FFFFFF" Foreground="#DDFFFFFF" BorderThickness="0"
                 FontFamily="Consolas" FontSize="12"/>
    </DockPanel>
</Window>
